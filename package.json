{
  "name": "health-app-monorepo",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "dev": "pnpm -r --parallel --filter @health/api --filter @health/mobile dev",
    "dev:full": "node ./scripts/dev-full.mjs",
    "dev:down": "node ./scripts/dev-down.mjs",
    "dev:mobile": "pnpm --filter @health/mobile dev",
    "dev:api": "pnpm --filter @health/api dev",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:push": "pnpm --filter @health/db db:push",
    "db:seed": "pnpm --filter @health/db db:seed",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "vitest": "^4.1.5"
  }
}
